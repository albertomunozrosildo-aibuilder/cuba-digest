<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Cuba Digest — {{ date_display }}</title>
<style>
/* ── Reset & Base ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:16px;-webkit-text-size-adjust:100%}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;background:#f5f4f0;color:#1a1a1a;line-height:1.6;min-height:100vh}
a{color:#c0392b;text-decoration:none}
a:hover{text-decoration:underline}
img{max-width:100%;display:block}

/* ── Layout ── */
.wrap{max-width:860px;margin:0 auto;padding:0 1rem}

/* ── Header ── */
.site-header{background:#1a1a1a;color:#fff;padding:.75rem 0;position:sticky;top:0;z-index:100;box-shadow:0 2px 8px rgba(0,0,0,.3)}
.header-inner{display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
.logo{font-size:1.25rem;font-weight:700;letter-spacing:-.5px;color:#fff}
.logo span{color:#e74c3c}
.header-meta{font-size:.8rem;color:#aaa}
.toggle-wrap{display:flex;align-items:center;gap:.5rem;font-size:.8rem;color:#ccc;white-space:nowrap}
.toggle-switch{position:relative;display:inline-block;width:36px;height:20px}
.toggle-switch input{opacity:0;width:0;height:0}
.toggle-slider{position:absolute;cursor:pointer;inset:0;background:#555;border-radius:20px;transition:.2s}
.toggle-slider::before{content:"";position:absolute;width:14px;height:14px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:.2s}
input:checked + .toggle-slider{background:#e74c3c}
input:checked + .toggle-slider::before{transform:translateX(16px)}

/* ── Core del Día ── */
.core-section{background:#fff;border-left:4px solid #e74c3c;margin:1.25rem 0;padding:1rem 1.25rem;border-radius:0 6px 6px 0;box-shadow:0 1px 4px rgba(0,0,0,.07)}
.core-section h2{font-size:1rem;font-weight:700;color:#e74c3c;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.75rem}
.core-list{list-style:none}
.core-list li{padding:.45rem 0;border-bottom:1px solid #f0f0f0}
.core-list li:last-child{border-bottom:none}
.core-list li::before{content:"•";color:#e74c3c;margin-right:.5rem}
.core-headline{font-size:.95rem;font-weight:600;color:#1a1a1a}
.core-headline a{color:inherit}
.core-headline a:hover{color:#c0392b}
.core-sources{font-size:.75rem;color:#999;margin-top:.2rem;margin-left:1rem}
.core-sources a{color:#888;margin-right:.4rem}
.core-sources a:hover{color:#c0392b}

/* ── Tabs ── */
.tabs-nav{display:flex;overflow-x:auto;background:#fff;border-bottom:2px solid #e8e8e8;margin-bottom:0;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.tabs-nav::-webkit-scrollbar{display:none}
.tab-btn{flex-shrink:0;padding:.65rem 1.1rem;font-size:.875rem;font-weight:600;color:#666;border:none;background:none;cursor:pointer;border-bottom:3px solid transparent;margin-bottom:-2px;transition:color .15s,border-color .15s;white-space:nowrap}
.tab-btn:hover{color:#1a1a1a}
.tab-btn.active{color:#e74c3c;border-bottom-color:#e74c3c}
.tab-panel{display:none;padding:1rem 0}
.tab-panel.active{display:block}

/* ── Topic Card ── */
.topic-card{background:#fff;border-radius:8px;margin-bottom:1.25rem;box-shadow:0 1px 4px rgba(0,0,0,.07);overflow:hidden}
.topic-header{padding:1rem 1.25rem .75rem;border-bottom:1px solid #f0f0f0}
.topic-name{font-size:1.05rem;font-weight:700;color:#1a1a1a;margin-bottom:.4rem}
.topic-meta{font-size:.78rem;color:#888}
.topic-body{padding:.75rem 1.25rem}
.topic-synthesis{font-size:.9rem;color:#444;line-height:1.65;margin-bottom:1rem;padding:.75rem;background:#fafaf8;border-radius:4px;border-left:3px solid #e8e0d0}
.section-label{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#999;margin:.75rem 0 .4rem}

/* ── Item ── */
.item{padding:.6rem 0;border-bottom:1px solid #f5f5f5}
.item:last-child{border-bottom:none}
.item-title{font-size:.9rem;font-weight:600;color:#1a1a1a;margin-bottom:.2rem}
.item-title a{color:inherit}
.item-title a:hover{color:#c0392b}
.item-meta{font-size:.75rem;color:#999;margin-bottom:.25rem}
.item-summary{font-size:.82rem;color:#555;line-height:1.55;margin:.25rem 0}
.item-insight{font-size:.78rem;color:#888;font-style:italic;margin-top:.2rem}
.read-link{display:inline-block;font-size:.75rem;font-weight:600;color:#e74c3c;margin-top:.3rem}
.read-link::after{content:" →"}

/* ── Video card ── */
.video-card{display:flex;gap:.85rem;padding:.75rem 0;border-bottom:1px solid #f0f0f0;align-items:flex-start}
.video-card:last-child{border-bottom:none}
.video-thumb{width:110px;flex-shrink:0;border-radius:4px;overflow:hidden;background:#eee;aspect-ratio:16/9;display:flex;align-items:center;justify-content:center}
.video-thumb img{width:100%;height:100%;object-fit:cover}
.video-thumb .no-thumb{font-size:1.4rem;color:#bbb}
.video-info{flex:1;min-width:0}
.video-title{font-size:.9rem;font-weight:600;color:#1a1a1a;line-height:1.35;margin-bottom:.2rem}
.video-title a{color:inherit}
.video-title a:hover{color:#c0392b}
.video-meta{font-size:.75rem;color:#999;margin-bottom:.25rem}
.video-summary{font-size:.82rem;color:#555;line-height:1.5}
.views-badge{background:#f0f0f0;border-radius:3px;padding:.1rem .4rem;font-size:.72rem;color:#666}

/* ── Source group (Medios tab) ── */
.source-group{background:#fff;border-radius:8px;margin-bottom:1rem;box-shadow:0 1px 4px rgba(0,0,0,.07);overflow:hidden}
.source-group-header{padding:.75rem 1.25rem;background:#fafafa;border-bottom:1px solid #f0f0f0;cursor:pointer;display:flex;justify-content:space-between;align-items:center}
.source-group-header:hover{background:#f5f5f5}
.source-name{font-size:.95rem;font-weight:700}
.source-desc{font-size:.75rem;color:#888;font-style:italic;margin-top:.15rem}
.source-count{font-size:.78rem;color:#888}
.source-group-body{padding:.25rem 1.25rem .75rem}
.source-item{padding:.45rem 0;border-bottom:1px solid #f8f8f8;font-size:.88rem}
.source-item:last-child{border-bottom:none}
.source-item-title a{color:#1a1a1a;font-weight:500}
.source-item-title a:hover{color:#c0392b}
.source-item-meta{font-size:.73rem;color:#aaa;margin-top:.1rem}

/* ── Tier section headings ── */
.tier-heading{font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;padding:.5rem 0 .3rem;color:#666;border-bottom:2px solid #e8e8e8;margin:1rem 0 .5rem}
.tier-independiente{color:#1a7a3e}
.tier-diaspora{color:#1a56a0}
.tier-internacional{color:#9a5000}
.tier-estatal{color:#9a1c1c}

/* ── Tier badges ── */
.badge{display:inline-block;padding:.1rem .45rem;border-radius:3px;font-size:.7rem;font-weight:600;vertical-align:middle}
.badge-independiente{background:#e6f4ea;color:#1a7a3e}
.badge-diaspora{background:#e8f0fe;color:#1a56a0}
.badge-internacional{background:#fef3e2;color:#9a5000}
.badge-estatal{background:#fce8e6;color:#9a1c1c}

/* ── Trending ── */
.trending-item{display:flex;align-items:flex-start;gap:.75rem;padding:.7rem 0;border-bottom:1px solid #f0f0f0}
.trending-item:last-child{border-bottom:none}
.trending-rank{font-size:1.4rem;font-weight:900;color:#e8e0d8;min-width:2rem;text-align:center;line-height:1}
.trending-info{flex:1}
.trending-title{font-size:.9rem;font-weight:600;color:#1a1a1a}
.trending-title a{color:inherit}
.trending-title a:hover{color:#c0392b}
.trending-meta{font-size:.75rem;color:#aaa;margin-top:.15rem}

/* ── Cuba Global ── */
.global-item{background:#fff;border-radius:6px;padding:.85rem 1rem;margin-bottom:.75rem;box-shadow:0 1px 3px rgba(0,0,0,.06);border-left:3px solid #f39c12}
.global-item-source{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#f39c12;margin-bottom:.25rem}
.global-item-title{font-size:.92rem;font-weight:600;color:#1a1a1a;margin-bottom:.3rem}
.global-item-title a{color:inherit}
.global-item-title a:hover{color:#c0392b}
.global-item-summary{font-size:.82rem;color:#555;line-height:1.55}
.global-item-meta{font-size:.73rem;color:#aaa;margin-top:.3rem}

/* ── Estatal section ── */
.estatal-warning{background:#fef3f2;border:1px solid #fdd;border-radius:6px;padding:.65rem .9rem;margin:.75rem 0;font-size:.8rem;color:#9a1c1c}
.estatal-warning strong{display:block;margin-bottom:.2rem}
.estatal-content{display:none}
.estatal-content.visible{display:block}

/* ── Empty states ── */
.empty-state{text-align:center;padding:2rem 1rem;color:#bbb;font-size:.9rem}
.empty-state .emoji{font-size:2rem;display:block;margin-bottom:.5rem}

/* ── Collapsible ── */
.collapsible-trigger{cursor:pointer;user-select:none}
.collapsible-trigger .chevron{display:inline-block;transition:transform .2s;margin-left:.25rem}
.collapsible-trigger.open .chevron{transform:rotate(180deg)}
.collapsible-body{display:none}
.collapsible-body.open{display:block}

/* ── More items toggle ── */
.more-toggle{font-size:.78rem;color:#888;cursor:pointer;padding:.3rem 0;display:inline-block}
.more-toggle:hover{color:#e74c3c}
.more-items{display:none}
.more-items.open{display:block}

/* ── Footer ── */
.site-footer{margin-top:2rem;padding:1.5rem 0;border-top:1px solid #e8e8e8;text-align:center;font-size:.75rem;color:#bbb}

/* ── Responsive ── */
@media(max-width:600px){
  .video-thumb{width:80px}
  .tab-btn{padding:.55rem .8rem;font-size:.8rem}
  .topic-name{font-size:.97rem}
}
</style>
</head>
<body>

<!-- ═══════════════════════════ HEADER ═══════════════════════════ -->
<header class="site-header">
  <div class="wrap header-inner">
    <div class="logo">🇨🇺 Cuba<span>Digest</span></div>
    <div class="header-meta">{{ date_display }}</div>
    <div class="toggle-wrap">
      <span>Cobertura estatal</span>
      <label class="toggle-switch" title="Mostrar/ocultar cobertura de medios estatales">
        <input type="checkbox" id="estatal-toggle">
        <span class="toggle-slider"></span>
      </label>
    </div>
  </div>
</header>

<main class="wrap" style="padding-top:1rem;padding-bottom:2rem">

<!-- ═══════════════════════════ CORE DEL DÍA ═══════════════════════════ -->
<section class="core-section">
  <h2>🔥 Core del día</h2>
  <ul class="core-list">
    {% for entry in core_del_dia %}
    <li>
      <div class="core-headline">
        {% if entry.url %}<a href="{{ entry.url }}" target="_blank" rel="noopener">{{ entry.text }}</a>{% else %}{{ entry.text }}{% endif %}
      </div>
      {% if entry.source_links %}
      <div class="core-sources">
        {% if entry.source_count >= 2 %}Cobertura:{% endif %}
        {% for sl in entry.source_links %}<a href="{{ sl.url }}" target="_blank" rel="noopener">{{ sl.name }}</a>{% if not loop.last %} · {% endif %}{% endfor %}
      </div>
      {% endif %}
    </li>
    {% else %}
    <li>No hay suficiente contenido para generar el core del día.</li>
    {% endfor %}
  </ul>
</section>

<!-- ═══════════════════════════ TABS ═══════════════════════════ -->
<nav class="tabs-nav" role="tablist">
  <button class="tab-btn active" role="tab" data-tab="temas">📌 Temas</button>
  <button class="tab-btn" role="tab" data-tab="medios">🏢 Medios</button>
  <button class="tab-btn" role="tab" data-tab="videos">🎥 Videos</button>
  <button class="tab-btn" role="tab" data-tab="trending">🔥 Trending</button>
  <button class="tab-btn" role="tab" data-tab="global">🌐 Cuba Global</button>
</nav>

<!-- ─────────── TAB: TEMAS ─────────── -->
<div id="tab-temas" class="tab-panel active" role="tabpanel">
  {% for topic in topics %}
  {% set topic_items = items_by_topic[topic.id] %}
  {% set featured = topic_items.featured %}
  {% set additional = topic_items.additional %}
  {% set videos = topic_items.videos %}
  {% set state = topic_items.state_coverage %}

  <article class="topic-card">
    <div class="topic-header">
      <div class="topic-name">📌 {{ topic.name }}</div>
      <div class="topic-meta">
        {% if topic.category and topic.category != 'general' %}
        <span class="badge" style="background:#f0f0f0;color:#555;margin-right:.3rem">{{ topic.category | replace('_',' ') | title }}</span>
        {% endif %}
        {{ topic.coverage.total_items }} fuente{{ 's' if topic.coverage.total_items != 1 else '' }}
        {% if topic.coverage.get('independiente') %} · {{ topic.coverage.independiente }} independiente{% endif %}
        {% if topic.coverage.get('diaspora') %} · {{ topic.coverage.diaspora }} diáspora{% endif %}
        {% if topic.coverage.get('internacional') %} · {{ topic.coverage.internacional }} internacional{% endif %}
      </div>
    </div>
    <div class="topic-body">

      {% if topic.synthesis.narrative %}
      <div class="topic-synthesis">{{ topic.synthesis.narrative }}</div>
      {% endif %}

      <!-- Featured articles -->
      {% if featured %}
      <div class="section-label">📰 Destacados</div>
      {% for item in featured %}
      <div class="item">
        <div class="item-title"><a href="{{ item.content.url }}" target="_blank" rel="noopener">{{ item.content.title }}</a></div>
        <div class="item-meta">
          <span class="badge badge-{{ item.source.tier }}">{{ item.source.tier }}</span>
          {{ item.source.name }}
          {% if item.content.published_date %} · {{ item.content.published_date | timeago }}{% endif %}
        </div>
        {% if item.enrichment.summary %}<div class="item-summary">{{ item.enrichment.summary }}</div>{% endif %}
        {% if item.enrichment.insight %}<div class="item-insight">{{ item.enrichment.insight }}</div>{% endif %}
        <a href="{{ item.content.url }}" class="read-link" target="_blank" rel="noopener">Leer original</a>
      </div>
      {% endfor %}
      {% endif %}

      <!-- Additional coverage -->
      {% if additional %}
      <div class="section-label">📄 Más cobertura ({{ additional | length }})</div>
      {% set show_all = additional | length <= 3 %}
      {% for item in additional[:3] %}
      <div class="source-item">
        <div class="source-item-title">
          <span class="badge badge-{{ item.source.tier }}">{{ item.source.tier }}</span>
          <a href="{{ item.content.url }}" target="_blank" rel="noopener">{{ item.content.title }}</a>
        </div>
        <div class="source-item-meta">{{ item.source.name }}{% if item.content.published_date %} · {{ item.content.published_date | timeago }}{% endif %}</div>
      </div>
      {% endfor %}
      {% if additional | length > 3 %}
      <span class="more-toggle" onclick="toggleMore(this)">+ Ver {{ additional | length - 3 }} más ▾</span>
      <div class="more-items">
        {% for item in additional[3:] %}
        <div class="source-item">
          <div class="source-item-title">
            <span class="badge badge-{{ item.source.tier }}">{{ item.source.tier }}</span>
            <a href="{{ item.content.url }}" target="_blank" rel="noopener">{{ item.content.title }}</a>
          </div>
          <div class="source-item-meta">{{ item.source.name }}{% if item.content.published_date %} · {{ item.content.published_date | timeago }}{% endif %}</div>
        </div>
        {% endfor %}
      </div>
      {% endif %}
      {% endif %}

      <!-- Videos -->
      {% if videos %}
      <div class="section-label">🎥 Videos relacionados ({{ videos | length }})</div>
      {% for item in videos %}
      <div class="video-card" style="padding:.5rem 0">
        <div class="video-info">
          <div class="video-title"><a href="{{ item.content.url }}" target="_blank" rel="noopener">{{ item.content.title }}</a></div>
          <div class="video-meta">
            {{ item.source.name }}
            {% if item.metadata.view_count %}<span class="views-badge">{{ item.metadata.view_count | views }}</span>{% endif %}
            {% if item.content.published_date %} · {{ item.content.published_date | timeago }}{% endif %}
          </div>
        </div>
      </div>
      {% endfor %}
      {% endif %}

      <!-- State coverage (toggle-gated) -->
      {% if state %}
      <div class="estatal-content" data-estatal>
        <div class="estatal-warning">
          <strong>🏛️ Cobertura estatal ({{ state | length }})</strong>
          Narrativa de medios controlados por el gobierno cubano. Se recomienda contrastar con fuentes independientes.
        </div>
        {% for item in state %}
        <div class="item">
          <div class="item-title"><a href="{{ item.content.url }}" target="_blank" rel="noopener">{{ item.content.title }}</a></div>
          <div class="item-meta">
            <span class="badge badge-estatal">estatal</span>
            {{ item.source.name }}
            {% if item.content.published_date %} · {{ item.content.published_date | timeago }}{% endif %}
          </div>
          <a href="{{ item.content.url }}" class="read-link" target="_blank" rel="noopener">Leer original</a>
        </div>
        {% endfor %}
      </div>
      {% endif %}

    </div>
  </article>
  {% else %}
  <div class="empty-state"><span class="emoji">📭</span>No hay temas para mostrar hoy.</div>
  {% endfor %}
</div>

<!-- ─────────── TAB: MEDIOS ─────────── -->
<div id="tab-medios" class="tab-panel" role="tabpanel">
  {% for tier, tier_label, tier_desc, tier_class in [
      ('independiente','📰 Medios Independientes','Periodismo cubano independiente — operan fuera o al margen del Estado cubano','tier-independiente'),
      ('diaspora','🌎 Voces de la Diáspora','Creadores y comentaristas cubanos en el exterior — opinión, análisis y testimonios','tier-diaspora'),
      ('internacional','🌐 Medios Internacionales','Prensa global que cubre Cuba — contexto desde medios extranjeros','tier-internacional')
  ] %}
  {% set tier_sources = items_by_source[tier] %}
  {% if tier_sources %}
  <div class="tier-heading {{ tier_class }}">{{ tier_label }}</div>
  <p style="font-size:.78rem;color:#aaa;margin:-0.3rem 0 .75rem">{{ tier_desc }}</p>
  {% for source_name, source_items in tier_sources.items() | sort %}
  {% set first_item = source_items[0] %}
  <div class="source-group">
    <div class="source-group-header collapsible-trigger open" onclick="toggleCollapsible(this)">
      <div>
        <span class="source-name">{{ source_name }}</span>
        {% if first_item.source.description %}<div class="source-desc">{{ first_item.source.description }}</div>{% endif %}
      </div>
      <span style="white-space:nowrap"><span class="source-count">{{ source_items | length }} item{{ 's' if source_items|length != 1 else '' }}</span> <span class="chevron">▾</span></span>
    </div>
    <div class="source-group-body collapsible-body open">
      {% for item in source_items %}
      <div class="source-item">
        <div class="source-item-title">
          <a href="{{ item.content.url }}" target="_blank" rel="noopener">{{ item.content.title }}</a>
        </div>
        <div class="source-item-meta">
          {% if item.content.published_date %}{{ item.content.published_date | timeago }}{% endif %}
          {% if item.type == 'video' %} · 🎥 video{% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endfor %}
  {% endif %}
  {% endfor %}

  <!-- Estatal (toggle-gated) -->
  {% set estatal_sources = items_by_source.get('estatal', {}) %}
  {% if estatal_sources %}
  <div class="estatal-content" data-estatal>
    <div class="tier-heading tier-estatal">🏛️ Estatales</div>
    <div class="estatal-warning">
      <strong>Medios controlados por el gobierno cubano.</strong>
      Recomendamos contrastar con fuentes independientes.
    </div>
    {% for source_name, source_items in estatal_sources.items() | sort %}
    <div class="source-group">
      <div class="source-group-header collapsible-trigger open" onclick="toggleCollapsible(this)">
        <span class="source-name">{{ source_name }}</span>
        <span><span class="source-count">{{ source_items | length }} items</span> <span class="chevron">▾</span></span>
      </div>
      <div class="source-group-body collapsible-body open">
        {% for item in source_items %}
        <div class="source-item">
          <div class="source-item-title"><a href="{{ item.content.url }}" target="_blank" rel="noopener">{{ item.content.title }}</a></div>
          <div class="source-item-meta">{% if item.content.published_date %}{{ item.content.published_date | timeago }}{% endif %}</div>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if not items_by_source %}
  <div class="empty-state"><span class="emoji">📭</span>No hay artículos disponibles.</div>
  {% endif %}
</div>

<!-- ─────────── TAB: VIDEOS ─────────── -->
<div id="tab-videos" class="tab-panel" role="tabpanel">
  {% set videos = items | selectattr("type","equalto","video") | list %}
  {% if videos %}
  <div class="section-label" style="margin-top:.25rem">🔥 Más relevantes hoy</div>
  {% for item in videos[:5] %}
  <div class="video-card">
    <div class="video-thumb">
      {% if item.metadata.thumbnail_url %}
      <img src="{{ item.metadata.thumbnail_url }}" alt="" loading="lazy">
      {% else %}
      <span class="no-thumb">▶</span>
      {% endif %}
    </div>
    <div class="video-info">
      <div class="video-title"><a href="{{ item.content.url }}" target="_blank" rel="noopener">{{ item.content.title }}</a></div>
      <div class="video-meta">
        <span class="badge badge-{{ item.source.tier }}">{{ item.source.tier }}</span>
        {{ item.source.name }}
        {% if item.metadata.view_count %} · <span class="views-badge">{{ item.metadata.view_count | views }}</span>{% endif %}
        {% if item.content.published_date %} · {{ item.content.published_date | timeago }}{% endif %}
      </div>
      {% if item.enrichment.summary %}<div class="video-summary">{{ item.enrichment.summary }}</div>{% endif %}
      {% if item.enrichment.insight %}<div class="item-insight">{{ item.enrichment.insight }}</div>{% endif %}
      <a href="{{ item.content.url }}" class="read-link" target="_blank" rel="noopener">Ver video</a>
    </div>
  </div>
  {% endfor %}

  {% if videos | length > 5 %}
  <div class="section-label">📺 Todos los videos ({{ videos | length }})</div>
  {% for item in videos[5:] %}
  <div class="video-card">
    <div class="video-info">
      <div class="video-title"><a href="{{ item.content.url }}" target="_blank" rel="noopener">{{ item.content.title }}</a></div>
      <div class="video-meta">
        {{ item.source.name }}
        {% if item.metadata.view_count %} · <span class="views-badge">{{ item.metadata.view_count | views }}</span>{% endif %}
        {% if item.content.published_date %} · {{ item.content.published_date | timeago }}{% endif %}
      </div>
    </div>
  </div>
  {% endfor %}
  {% endif %}

  {% else %}
  <div class="empty-state"><span class="emoji">🎬</span>No hay videos disponibles hoy.</div>
  {% endif %}
</div>

<!-- ─────────── TAB: TRENDING ─────────── -->
<div id="tab-trending" class="tab-panel" role="tabpanel">
  {% set trending = items | sort(attribute='scoring.total_score', reverse=True) %}
  {% if trending %}
  <div class="section-label" style="margin-top:.25rem">📊 Lo más relevante hoy</div>
  {% for item in trending[:10] %}
  <div class="trending-item">
    <div class="trending-rank">{{ loop.index }}</div>
    <div class="trending-info">
      <div class="trending-title">
        {% if item.type == 'video' %}🎥 {% endif %}
        <a href="{{ item.content.url }}" target="_blank" rel="noopener">{{ item.content.title }}</a>
      </div>
      <div class="trending-meta">
        <span class="badge badge-{{ item.source.tier }}">{{ item.source.tier }}</span>
        {{ item.source.name }}
        {% if item.type == 'video' and item.metadata.view_count %} · <span class="views-badge">{{ item.metadata.view_count | views }}</span>{% endif %}
        {% if item.content.published_date %} · {{ item.content.published_date | timeago }}{% endif %}
        · <span style="font-size:.7rem;color:#bbb">relevancia {{ "%.0f"|format(item.scoring.total_score * 100) }}%</span>
      </div>
    </div>
  </div>
  {% endfor %}

  {% set top_videos = items | selectattr("type","equalto","video") | sort(attribute='metadata.view_count', reverse=True) | list %}
  {% if top_videos %}
  <div class="section-label" style="margin-top:1rem">🔥 Más vistos en YouTube</div>
  {% for item in top_videos[:5] %}
  <div class="trending-item">
    <div class="trending-rank">{{ loop.index }}</div>
    <div class="trending-info">
      <div class="trending-title"><a href="{{ item.content.url }}" target="_blank" rel="noopener">{{ item.content.title }}</a></div>
      <div class="trending-meta">
        {{ item.source.name }}
        {% if item.metadata.view_count %} · <span class="views-badge">{{ item.metadata.view_count | views }}</span>{% endif %}
      </div>
    </div>
  </div>
  {% endfor %}
  {% endif %}

  {% else %}
  <div class="empty-state"><span class="emoji">📊</span>No hay datos de trending disponibles.</div>
  {% endif %}
</div>

<!-- ─────────── TAB: CUBA GLOBAL ─────────── -->
<div id="tab-global" class="tab-panel" role="tabpanel">
  {% set global_items = items | selectattr("source.tier","equalto","internacional") | list %}

  {% if global_items %}
  <p style="font-size:.85rem;color:#888;margin-bottom:1rem">Noticias sobre Cuba publicadas por medios internacionales</p>
  {% for item in global_items | sort(attribute='scoring.total_score', reverse=True) %}
  <div class="global-item">
    <div class="global-item-source">🌍 {{ item.source.name }}</div>
    <div class="global-item-title"><a href="{{ item.content.url }}" target="_blank" rel="noopener">{{ item.content.title }}</a></div>
    {% if item.enrichment.summary %}<div class="global-item-summary">{{ item.enrichment.summary }}</div>{% endif %}
    {% if item.enrichment.insight %}<div class="item-insight">{{ item.enrichment.insight }}</div>{% endif %}
    <div class="global-item-meta">
      {% if item.content.published_date %}{{ item.content.published_date | timeago }}{% endif %}
      · <a href="{{ item.content.url }}" target="_blank" rel="noopener" class="read-link">Leer original</a>
    </div>
  </div>
  {% endfor %}

  {% else %}
  <div class="empty-state">
    <span class="emoji">🌐</span>
    <p>No hay cobertura internacional de Cuba disponible hoy.</p>
    <p style="font-size:.8rem;color:#bbb;margin-top:.5rem">Los medios internacionales configurados (BBC Mundo, Reuters) no publicaron artículos sobre Cuba en las últimas 48 horas.</p>
  </div>
  {% endif %}
</div>

</main>

<footer class="site-footer">
  <div class="wrap">
    Cuba Digest v2.0 · Generado el {{ generated_at }} · {{ stats.total }} items · {{ stats.sources }} fuentes
  </div>
</footer>

<script>
// ── Tab switching ─────────────────────────────────────────────────────────────
(function() {
  var btns = document.querySelectorAll('.tab-btn');
  btns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var target = this.getAttribute('data-tab');
      document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
      document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
      this.classList.add('active');
      var panel = document.getElementById('tab-' + target);
      if (panel) panel.classList.add('active');
    });
  });
})();

// ── Estatal toggle ────────────────────────────────────────────────────────────
(function() {
  var toggle = document.getElementById('estatal-toggle');
  if (!toggle) return;

  function applyToggle() {
    var show = toggle.checked;
    document.querySelectorAll('[data-estatal]').forEach(function(el) {
      el.classList.toggle('visible', show);
    });
    try { sessionStorage.setItem('estatal', show ? '1' : '0'); } catch(e) {}
  }

  // Restore from session
  try {
    if (sessionStorage.getItem('estatal') === '1') toggle.checked = true;
  } catch(e) {}

  toggle.addEventListener('change', applyToggle);
  applyToggle();
})();

// ── Collapsible source groups ─────────────────────────────────────────────────
function toggleCollapsible(trigger) {
  trigger.classList.toggle('open');
  var body = trigger.nextElementSibling;
  if (body) body.classList.toggle('open');
}

// ── More items toggle ─────────────────────────────────────────────────────────
function toggleMore(el) {
  var more = el.nextElementSibling;
  if (!more) return;
  var open = more.classList.toggle('open');
  el.textContent = open ? '▴ Ver menos' : el.textContent.replace('▴ Ver menos', '') || '+ Ver más ▾';
}
</script>

</body>
</html>
